# Rudra Multi-Model Agent Framework — Environment Variables
# Copy to .env and fill in your credentials

# ─── Required: at least one model API key ─────────────────────────────────────

# Anthropic Claude (primary reasoning model — strongly recommended)
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# OpenAI / OpenClaw (orchestration and routing)
OPENAI_API_KEY=your_openai_api_key_here

# Alibaba Qwen 2.5 (multilingual, code generation, data pipelines)
# Get at: https://dashscope.aliyuncs.com
DASHSCOPE_API_KEY=your_dashscope_api_key_here

# ─── Optional: Enhanced capabilities ──────────────────────────────────────────

# Canva (executive presentations, dashboards, roadmaps)
# Get at: https://www.canva.com/developers/
CANVA_ACCESS_TOKEN=your_canva_access_token_here

# Databricks (vector search, analytics, ML pipelines)
DATABRICKS_HOST=https://your-workspace.azuredatabricks.net
DATABRICKS_TOKEN=your_databricks_personal_access_token
DATABRICKS_WAREHOUSE_ID=your_sql_warehouse_id

# Luma AI (photorealistic video generation)
# Get at: https://lumalabs.ai/dream-machine/api
LUMA_AI_KEY=your_luma_ai_key_here
